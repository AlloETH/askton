TELEGRAM_TOKEN=your_botfather_token

# LLM Provider: "claude" or "rapidapi"
LLM_PROVIDER=rapidapi

# RapidAPI (ChatGPT4-2)
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=chatgpt-42.p.rapidapi.com
RAPIDAPI_URL=https://chatgpt-42.p.rapidapi.com/conversationgpt4-2

# Claude (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-5

# Claude OAuth credentials (for Docker/server deployment)
# Copy the full JSON content of ~/.claude/.credentials.json here
CLAUDE_CREDENTIALS={"claudeAiOauth":{"accessToken":"","refreshToken":"your_refresh_token","expiresAt":0}}

# MTProto (for resolving any @username — run: npx ts-node scripts/mtproto-login.ts)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_SESSION=

BOT_USERNAME=asktonbot
TONAPI_KEY=your_tonapi_key
GIFTASSET_API_KEY=your_giftasset_api_key

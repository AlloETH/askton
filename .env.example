TELEGRAM_TOKEN=your_botfather_token

# LLM provider & model (uses @mariozechner/pi-ai)
# Supported providers: anthropic, openai, google, groq, xai, openrouter, mistral, cerebras, etc.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5

# Set the API key for your chosen provider:
# ANTHROPIC_API_KEY=your_key
# OPENAI_API_KEY=your_key
# GEMINI_API_KEY=your_key
# GROQ_API_KEY=your_key
# XAI_API_KEY=your_key
# OPENROUTER_API_KEY=your_key
# MISTRAL_API_KEY=your_key

# MTProto (for resolving any @username — run: npx ts-node scripts/mtproto-login.ts)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_SESSION=

BOT_USERNAME=asktonbot
TONAPI_KEY=your_tonapi_key
GIFTASSET_API_KEY=your_giftasset_api_key
